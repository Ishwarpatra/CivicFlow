# ─── Required ────────────────────────────────────────────────────────────────
# Gemini AI API key — get from https://aistudio.google.com
GEMINI_API_KEY=

# Secure random string for signing session cookies (change before deploying)
SESSION_SECRET=

# ─── Google Services (strongly recommended) ───────────────────────────────────
# Google Maps JavaScript API key — enables real map embeds in Find My Booth
# Enable "Maps JavaScript API" and "Maps Embed API" at console.cloud.google.com
GOOGLE_MAPS_API_KEY=

# Google Civic Information API key — returns real representative data
# Enable "Google Civic Information API" at console.cloud.google.com
GOOGLE_CIVIC_API_KEY=

# ─── Firebase Firestore (persistent vote storage) ─────────────────────────────
# Create a service account at console.firebase.google.com → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── CORS & Runtime ───────────────────────────────────────────────────────────
# Comma-separated allowed origins in production (e.g. https://civicflow.in)
ALLOWED_ORIGINS=http://localhost:8080
NODE_ENV=development
PORT=8080
