{
  "name": "civicflow-htmx-express",
  "private": true,
  "version": "0.1.0-alpha",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run build:css -- --watch\" \"npm run copy-assets\" \"tsx server.ts\"",
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./public/style.css --minify",
    "copy-assets": "node -e \"const fs=require('fs');fs.mkdirSync('public/js',{recursive:true});fs.copyFileSync('node_modules/htmx.org/dist/htmx.min.js','public/js/htmx.min.js');fs.copyFileSync('node_modules/alpinejs/dist/cdn.min.js','public/js/alpine.min.js')\"",
    "build": "npm run build:css && npm run copy-assets && tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "1.29.0",
    "alpinejs": "^3.14.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.0.0",
    "connect-sqlite3": "^0.9.15",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "htmx.org": "^2.0.0",
    "isomorphic-dompurify": "^2.10.0",
    "marked": "^12.0.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0-alpha.14",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.10",
    "@types/connect-sqlite3": "^0.9.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "concurrently": "^8.2.2",
    "pino-pretty": "^11.1.0",
    "tailwindcss": "^4.0.0-alpha.14",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
