{
  "name": "civicflow-htmx-express",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run build:css -- --watch\" \"npm run copy-assets\" \"tsx server.ts\"",
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./public/style.css --minify",
    "copy-assets": "mkdir -p public/js && cp node_modules/htmx.org/dist/htmx.min.js public/js/htmx.min.js && cp node_modules/alpinejs/dist/cdn.min.js public/js/alpine.min.js",
    "build": "npm run build:css && npm run copy-assets && tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "alpinejs": "^3.15.11",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "connect-sqlite3": "^0.9.16",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.0.0",
    "htmx.org": "^2.0.10",
    "isomorphic-dompurify": "^3.9.0",
    "marked": "^18.0.2",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/connect-sqlite3": "^0.9.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.12",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.5"
  }
}
